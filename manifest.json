{

    "manifest_version": 2, 
    "version": "1.0.0", 
    "name": "tAIlor",
    "description": "AI-assisted LaTeX resume tailoring sidebar",

    "sidebar_action": {
        "default_title": "tAIlor",
        "default_panel": "src/sidebar/sidebar.html",
        "open_at_install":true
    },

    "permissions": [
        "activeTab", 
        "storage"
    ], 

    "background": { 
        "scripts": ["src/background/background.ts"]
    },
    "content_scripts": [
        {
            "matches": ["*://*/*"],
            "js": ["src/content/content.ts"]
        }
    ]

}